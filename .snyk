# Snyk (https://snyk.io) policy file, patches or ignores known vulnerabilities.
version: v1.25.1
# ignores vulnerabilities until expiry date; change duration by modifying expiry date
ignore:
  SNYK-JS-INFLIGHT-6095116:
    - '*':
        reason: No patch available - transitive dependency from jest
        expires: 2026-07-12T00:00:00.000Z
        created: 2026-01-12T16:45:54.765Z
  SNYK-JS-JSYAML-17342520:
    - '*':
        reason: Fix only in js-yaml 4.x; transitive via @istanbuljs/load-nyc-config which needs the v3 safeLoad API
        expires: 2026-09-19T00:00:00.000Z
        created: 2026-06-19T00:00:00.000Z
# patches apply the minimum changes required to fix a vulnerability
patch:
  SNYK-JS-LODASH-567746:
    - table > lodash:
        patched: '2020-04-30T21:41:26.435Z'
